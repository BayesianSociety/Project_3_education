{
  "task_summary": "Design a single Next.js 16 TypeScript codebase that delivers the 3-level WebGL block-coding game, SQLite telemetry APIs, and analytics tooling per brief.",
  "project_brief_path": "Project_description.md",
  "stages": [
    "Environment preflight",
    "Context analysis",
    "Planner generation",
    "Planner schema validation",
    "Planner repair loop if needed",
    "Worker generation",
    "Artifact validation",
    "Build validation",
    "Runtime validation",
    "Final acceptance summary"
  ],
  "roles": [
    "Orchestrator",
    "Context Analyst",
    "Architect",
    "Backend Producer",
    "Frontend Producer",
    "Verification Agent"
  ],
  "shared_artifacts": [
    "Project_description.md",
    "plans/implementation_plan.md",
    "contracts/backend_contract.md",
    "contracts/frontend_contract.md"
  ],
  "contracts": [
    "contracts/backend_contract.md",
    "contracts/frontend_contract.md",
    "contracts/qa_contract.md"
  ],
  "validation_rules": [
    {
      "name": "next_config_present",
      "kind": "file_exists",
      "target": "next.config.mjs",
      "expectation": "Ensures Next.js configuration exists for the unified app."
    },
    {
      "name": "controls_speed_toggle",
      "kind": "contains_text",
      "target": "components/ControlsPanel.tsx",
      "expectation": "Includes user-facing copy \"Speed\" for the toggle UI."
    },
    {
      "name": "puzzle_progress_table",
      "kind": "contains_text",
      "target": "lib/db/schema.ts",
      "expectation": "Schema declares CREATE TABLE IF NOT EXISTS puzzle_progress"
    },
    {
      "name": "analytics_dashboard_component",
      "kind": "file_exists",
      "target": "components/AnalyticsDashboard.tsx",
      "expectation": "Analytics UI entry point exists."
    },
    {
      "name": "webgl_renderer_dependency",
      "kind": "contains_text",
      "target": "package.json",
      "expectation": "Includes \"pixi.js\" dependency for WebGL rendering."
    }
  ],
  "build_expectations": [
    {
      "name": "next_build",
      "command": "./node_modules/.bin/next build",
      "offline_safe": true
    },
    {
      "name": "lint_checks",
      "command": "./node_modules/.bin/next lint",
      "offline_safe": true
    }
  ],
  "runtime_expectations": [
    {
      "name": "dev_server",
      "command": "./node_modules/.bin/next dev",
      "offline_safe": true
    },
    {
      "name": "db_check",
      "command": "node scripts/check_db.ts",
      "offline_safe": true
    }
  ],
  "worker_tasks": [
    {
      "role": "Backend Producer",
      "summary": "Own Next.js project scaffolding, shared config, puzzle data model, better-sqlite3 client, schema/init scripts, telemetry ingestion endpoints, analytics read APIs, and DB verification tooling.",
      "owned_paths": [
        "package.json",
        "tsconfig.json",
        "next.config.mjs",
        "app/api/session/start/route.ts",
        "app/api/session/end/route.ts",
        "app/api/events/batch/route.ts",
        "app/api/analytics/overview/route.ts",
        "app/api/analytics/puzzle/[id]/route.ts",
        "app/api/analytics/attempt/[id]/route.ts",
        "lib/db/client.ts",
        "lib/db/schema.ts",
        "lib/db/migrations.ts",
        "lib/telemetry/ingest.ts",
        "lib/telemetry/types.ts",
        "lib/puzzles/definitions.ts",
        "scripts/check_db.ts"
      ],
      "required_outputs": [
        "package.json",
        "lib/db/schema.ts",
        "app/api/events/batch/route.ts",
        "lib/puzzles/definitions.ts",
        "scripts/check_db.ts"
      ],
      "read_only_inputs": [
        "Project_description.md",
        "design/layout_refs/layout.png",
        "public/assets/backgrounds/background.jpg",
        "public/assets/sprites/main_character.png",
        "public/assets/sprites/place.png",
        "public/assets/sprites/obstacle.png",
        "public/assets/sprites/food.png",
        "plans/implementation_plan.md",
        "contracts/backend_contract.md"
      ],
      "forbidden_paths": [
        "app/layout.tsx",
        "app/page.tsx",
        "app/puzzles/page.tsx",
        "app/puzzles/[id]/page.tsx",
        "app/analytics/page.tsx",
        "app/analytics/[id]/page.tsx",
        "components/GameShell.tsx",
        "components/BlockWorkspace.tsx",
        "components/SceneCanvas.tsx",
        "components/ControlsPanel.tsx",
        "components/FailureModal.tsx",
        "components/AnalyticsDashboard.tsx",
        "hooks/usePuzzleRunner.ts",
        "hooks/useTelemetry.ts",
        "styles/theme.css",
        "lib/game/engine.ts",
        "lib/game/simulator.ts",
        "lib/game/replay.ts"
      ],
      "dependencies": [],
      "contracts": [
        "contracts/backend_contract.md"
      ],
      "validation_rules": [
        {
          "name": "schema_tables_declared",
          "kind": "contains_text",
          "target": "lib/db/schema.ts",
          "expectation": "CREATE TABLE IF NOT EXISTS attempts"
        },
        {
          "name": "telemetry_route_exports_post",
          "kind": "contains_text",
          "target": "app/api/events/batch/route.ts",
          "expectation": "export async function POST"
        },
        {
          "name": "puzzle_data_export",
          "kind": "contains_text",
          "target": "lib/puzzles/definitions.ts",
          "expectation": "export const puzzles"
        }
      ]
    },
    {
      "role": "Frontend Producer",
      "summary": "Create the UX: landing, map, puzzles, analytics pages, themed block workspace with left library/right code area, WebGL scene canvas, execution engine, telemetry hooks, controls, failure messaging, progression UI, and replay tools.",
      "owned_paths": [
        "app/layout.tsx",
        "app/page.tsx",
        "app/puzzles/page.tsx",
        "app/puzzles/[id]/page.tsx",
        "app/analytics/page.tsx",
        "app/analytics/[id]/page.tsx",
        "components/GameShell.tsx",
        "components/BlockWorkspace.tsx",
        "components/SceneCanvas.tsx",
        "components/ControlsPanel.tsx",
        "components/FailureModal.tsx",
        "components/AnalyticsDashboard.tsx",
        "components/ShowCodePanel.tsx",
        "hooks/usePuzzleRunner.ts",
        "hooks/useTelemetry.ts",
        "lib/game/engine.ts",
        "lib/game/simulator.ts",
        "lib/game/replay.ts",
        "styles/theme.css"
      ],
      "required_outputs": [
        "app/page.tsx",
        "components/BlockWorkspace.tsx",
        "components/SceneCanvas.tsx",
        "components/ControlsPanel.tsx",
        "components/FailureModal.tsx",
        "components/AnalyticsDashboard.tsx",
        "lib/game/engine.ts",
        "lib/game/replay.ts"
      ],
      "read_only_inputs": [
        "Project_description.md",
        "design/layout_refs/layout.png",
        "public/assets/backgrounds/background.jpg",
        "public/assets/sprites/main_character.png",
        "public/assets/sprites/place.png",
        "public/assets/sprites/obstacle.png",
        "public/assets/sprites/food.png",
        "plans/implementation_plan.md",
        "contracts/frontend_contract.md",
        "lib/puzzles/definitions.ts",
        "lib/db/schema.ts",
        "lib/telemetry/types.ts",
        "app/api/analytics/overview/route.ts"
      ],
      "forbidden_paths": [
        "package.json",
        "tsconfig.json",
        "next.config.mjs",
        "app/api/session/start/route.ts",
        "app/api/session/end/route.ts",
        "app/api/events/batch/route.ts",
        "app/api/analytics/overview/route.ts",
        "app/api/analytics/puzzle/[id]/route.ts",
        "app/api/analytics/attempt/[id]/route.ts",
        "lib/db/client.ts",
        "lib/db/migrations.ts",
        "lib/db/schema.ts",
        "lib/telemetry/ingest.ts",
        "scripts/check_db.ts"
      ],
      "dependencies": [
        "Backend Producer"
      ],
      "contracts": [
        "contracts/frontend_contract.md"
      ],
      "validation_rules": [
        {
          "name": "oops_hint_message_present",
          "kind": "contains_text",
          "target": "components/FailureModal.tsx",
          "expectation": "Oops!"
        },
        {
          "name": "show_code_toggle_present",
          "kind": "contains_text",
          "target": "components/BlockWorkspace.tsx",
          "expectation": "Show Code"
        },
        {
          "name": "scene_canvas_uses_pixi",
          "kind": "contains_text",
          "target": "components/SceneCanvas.tsx",
          "expectation": "from 'pixi.js'"
        }
      ]
    }
  ]
}