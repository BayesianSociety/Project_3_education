{
  "task_summary": "Build the Block Coding Puzzles Next.js 16 app with Blockly workspace, WebGL renderer, and SQLite telemetry/analytics that satisfy the brief end-to-end.",
  "project_brief_path": "Project_description.md",
  "stages": [
    "Environment preflight",
    "Context analysis",
    "Planner generation",
    "Planner schema validation",
    "Planner repair loop if needed",
    "Worker generation",
    "Artifact validation",
    "Build validation",
    "Runtime validation",
    "Final acceptance summary"
  ],
  "roles": [
    "Orchestrator",
    "Context Analyst",
    "Architect",
    "Backend Producer",
    "Frontend Producer",
    "Verification Agent"
  ],
  "shared_artifacts": [
    "Project_description.md",
    "Design_of_project_description.md",
    "Game_description.md",
    "docs/architecture/api-contracts.md",
    "docs/architecture/block-engine-contract.md",
    "docs/architecture/telemetry-contract.md"
  ],
  "contracts": [
    "docs/architecture/api-contracts.md",
    "docs/architecture/block-engine-contract.md",
    "docs/architecture/telemetry-contract.md"
  ],
  "validation_rules": [
    {
      "name": "PuzzleDataFile",
      "kind": "file_exists",
      "target": "lib/puzzles/definitions.ts",
      "expectation": "Data module exports exactly three sequential puzzles with layout coordinates, goal text, available blocks, constraints, and hint hooks tied to asset IDs."
    },
    {
      "name": "WorkspaceContract",
      "kind": "contains_text",
      "target": "components/Workspace/BlockWorkspace.tsx",
      "expectation": "Workspace enforces the fixed On Start root, command categories, Show Code toggle, and displays a pink/violet warning for disconnected blocks."
    },
    {
      "name": "AnalyticsRoutes",
      "kind": "route_contract",
      "target": "app/api/analytics",
      "expectation": "Implements GET /api/analytics/summary, /api/analytics/puzzle/[puzzleId], /api/analytics/attempts/[attemptId], and /api/analytics/movements/[attemptId] returning analytics JSON."
    },
    {
      "name": "SessionEndpoints",
      "kind": "route_contract",
      "target": "app/api/session",
      "expectation": "Provides POST /api/session/start and POST /api/session/end that manage SQLite rows and return identifiers for telemetry usage."
    },
    {
      "name": "TelemetrySmokeTest",
      "kind": "offline_command",
      "target": "node scripts/verify/simulate_run.ts",
      "expectation": "Command seeds puzzle data, simulates Play/Reset, submits telemetry batch, and prints attempts/events/movements counts without network use."
    },
    {
      "name": "SQLiteMovementRows",
      "kind": "sqlite_artifact",
      "target": "var/data/block_coding.sqlite",
      "expectation": "After running the smoke command the database contains attempts, events, and ordered movement rows for replay queries."
    },
    {
      "name": "WebGLRendererImplementation",
      "kind": "file_exists",
      "target": "lib/game/renderer/webglPipeline.ts",
      "expectation": "Renderer module drives WebGL-based layered scenes with asset placement, smooth animation, collisions, and keyboard-accessible camera controls."
    }
  ],
  "build_expectations": [
    {
      "name": "Lint",
      "command": "npm run lint",
      "offline_safe": true
    },
    {
      "name": "NextBuild",
      "command": "npm run build",
      "offline_safe": true
    }
  ],
  "runtime_expectations": [
    {
      "name": "DevServer",
      "command": "SQLITE_DB_DIRECTORY=var/data npm run dev -- --hostname 127.0.0.1 --port 4000",
      "offline_safe": true
    },
    {
      "name": "SimulateTelemetry",
      "command": "node scripts/verify/simulate_run.ts",
      "offline_safe": true
    }
  ],
  "worker_tasks": [
    {
      "role": "Backend Producer",
      "summary": "Stand up the Next.js configuration, SQLite schema bootstrap, puzzle data module, telemetry ingestion pipeline, analytics query layer, REST endpoints, and verification/contract docs.",
      "owned_paths": [
        "package.json",
        "tsconfig.json",
        "next.config.mjs",
        "next-env.d.ts",
        "app/api/session/start/route.ts",
        "app/api/session/end/route.ts",
        "app/api/attempts/start/route.ts",
        "app/api/attempts/complete/route.ts",
        "app/api/events/batch/route.ts",
        "app/api/analytics/summary/route.ts",
        "app/api/analytics/puzzle/[puzzleId]/route.ts",
        "app/api/analytics/attempts/[attemptId]/route.ts",
        "app/api/analytics/movements/[attemptId]/route.ts",
        "lib/db/client.ts",
        "lib/db/migrations.ts",
        "lib/db/schema.ts",
        "lib/puzzles/definitions.ts",
        "lib/puzzles/types.ts",
        "lib/server/sessionService.ts",
        "lib/server/attemptService.ts",
        "lib/server/analyticsService.ts",
        "lib/server/progressionService.ts",
        "lib/telemetry/ingest.ts",
        "lib/telemetry/analytics.ts",
        "lib/api/contracts.ts",
        "docs/architecture/api-contracts.md",
        "docs/architecture/telemetry-contract.md",
        "scripts/verify/simulate_run.ts",
        "scripts/verify/seedAnalytics.ts"
      ],
      "required_outputs": [
        "package.json",
        "app/api/session/start/route.ts",
        "app/api/events/batch/route.ts",
        "app/api/analytics/summary/route.ts",
        "lib/puzzles/definitions.ts",
        "lib/server/sessionService.ts",
        "docs/architecture/api-contracts.md",
        "scripts/verify/simulate_run.ts"
      ],
      "read_only_inputs": [
        "Project_description.md",
        "Design_of_project_description.md",
        "Game_description.md",
        "design/layout_refs/layout.png",
        "public/assets/backgrounds/background.jpg",
        "public/assets/sprites/main_character.png",
        "public/assets/sprites/obstacle.png",
        "public/assets/sprites/place.png",
        "public/assets/sprites/food.png",
        "scripts/resetDb.ts"
      ],
      "forbidden_paths": [
        "public/assets/backgrounds/background.jpg",
        "public/assets/sprites/main_character.png",
        "public/assets/sprites/obstacle.png",
        "public/assets/sprites/place.png",
        "public/assets/sprites/food.png",
        "design/layout_refs/layout.png"
      ],
      "dependencies": [],
      "contracts": [
        "docs/architecture/api-contracts.md",
        "docs/architecture/telemetry-contract.md"
      ],
      "validation_rules": [
        {
          "name": "SessionStartRoute",
          "kind": "file_exists",
          "target": "app/api/session/start/route.ts",
          "expectation": "Handler validates payload, creates/updates users and sessions, and returns IDs for telemetry linkage."
        },
        {
          "name": "SessionEndRoute",
          "kind": "file_exists",
          "target": "app/api/session/end/route.ts",
          "expectation": "Completes sessions, updates attempts, and records ended_at timestamps."
        },
        {
          "name": "TelemetryBatchRoute",
          "kind": "contains_text",
          "target": "app/api/events/batch/route.ts",
          "expectation": "Route parses arrays of events/movements, invokes persistTelemetryBatch, and rejects empty submissions."
        },
        {
          "name": "AnalyticsSummaryRoute",
          "kind": "contains_text",
          "target": "app/api/analytics/summary/route.ts",
          "expectation": "Uses buildAnalyticsSummary from lib/telemetry/analytics to deliver totals, puzzle summaries, and recent attempts."
        },
        {
          "name": "SimulateRunScript",
          "kind": "offline_command",
          "target": "node scripts/verify/simulate_run.ts",
          "expectation": "Script instantiates puzzles, fakes execution, and logs attempts/events/movements counts via better-sqlite3."
        }
      ]
    },
    {
      "role": "Frontend Producer",
      "summary": "Deliver the landing, level select, puzzle UI, Blockly workspace, WebGL scene/runtime, analytics dashboards, telemetry bridge, and block-engine contract that meet visual and accessibility goals.",
      "owned_paths": [
        "app/layout.tsx",
        "app/page.tsx",
        "app/globals.css",
        "app/levels/page.tsx",
        "app/puzzles/[puzzleId]/page.tsx",
        "app/analytics/page.tsx",
        "components/Layout/TopBar.tsx",
        "components/Layout/PageShell.tsx",
        "components/Landing/HeroPanel.tsx",
        "components/Landing/HowToPlay.tsx",
        "components/Puzzles/LevelSelectGrid.tsx",
        "components/Puzzles/PuzzleHUD.tsx",
        "components/Puzzles/GoalNarration.tsx",
        "components/Puzzles/FailureHintOverlay.tsx",
        "components/Workspace/BlockWorkspace.tsx",
        "components/Workspace/ToolboxCategories.tsx",
        "components/Workspace/CodePreview.tsx",
        "components/Workspace/DisconnectedWarning.tsx",
        "components/Controls/ExecutionControls.tsx",
        "components/Controls/SpeedToggle.tsx",
        "components/Controls/PlayResetButtons.tsx",
        "components/Controls/TextToSpeechButton.tsx",
        "components/Scene/WebGLSceneCanvas.tsx",
        "components/Scene/SceneOrchestrator.tsx",
        "components/Scene/AnalyticsReplayCanvas.tsx",
        "components/Analytics/AnalyticsDashboard.tsx",
        "components/Analytics/EventStreamPanel.tsx",
        "components/Analytics/AttemptReplayPanel.tsx",
        "components/Analytics/PuzzleDetailPanel.tsx",
        "hooks/usePuzzleRunner.ts",
        "hooks/useWorkspaceWarnings.ts",
        "hooks/useTelemetryBuffer.ts",
        "hooks/useSessionLifecycle.ts",
        "hooks/useHintSystem.ts",
        "lib/game/types.ts",
        "lib/game/world.ts",
        "lib/game/compiler.ts",
        "lib/game/runtime.ts",
        "lib/game/failureReasons.ts",
        "lib/game/hints.ts",
        "lib/game/renderer/webglPipeline.ts",
        "lib/game/renderer/textureCache.ts",
        "lib/game/blockly/theme.ts",
        "lib/game/blockly/toolbox.ts",
        "lib/game/blockly/blocks.ts",
        "lib/game/blockly/codeExport.ts",
        "lib/client/telemetryBridge.ts",
        "lib/state/puzzleStore.ts",
        "lib/state/uiStore.ts",
        "styles/blockly-theme.css",
        "styles/scene.css",
        "docs/architecture/block-engine-contract.md"
      ],
      "required_outputs": [
        "app/puzzles/[puzzleId]/page.tsx",
        "app/analytics/page.tsx",
        "components/Workspace/BlockWorkspace.tsx",
        "components/Scene/WebGLSceneCanvas.tsx",
        "components/Analytics/AnalyticsDashboard.tsx",
        "lib/game/runtime.ts",
        "lib/game/renderer/webglPipeline.ts",
        "lib/client/telemetryBridge.ts",
        "styles/blockly-theme.css",
        "docs/architecture/block-engine-contract.md"
      ],
      "read_only_inputs": [
        "Project_description.md",
        "Design_of_project_description.md",
        "Game_description.md",
        "design/layout_refs/layout.png",
        "public/assets/backgrounds/background.jpg",
        "public/assets/sprites/main_character.png",
        "public/assets/sprites/obstacle.png",
        "public/assets/sprites/place.png",
        "public/assets/sprites/food.png",
        "lib/puzzles/definitions.ts",
        "docs/architecture/api-contracts.md",
        "docs/architecture/telemetry-contract.md"
      ],
      "forbidden_paths": [
        "public/assets/backgrounds/background.jpg",
        "public/assets/sprites/main_character.png",
        "public/assets/sprites/obstacle.png",
        "public/assets/sprites/place.png",
        "public/assets/sprites/food.png",
        "design/layout_refs/layout.png"
      ],
      "dependencies": [
        "lib/puzzles/definitions.ts",
        "docs/architecture/api-contracts.md",
        "docs/architecture/telemetry-contract.md"
      ],
      "contracts": [
        "docs/architecture/block-engine-contract.md"
      ],
      "validation_rules": [
        {
          "name": "LevelSelectPage",
          "kind": "file_exists",
          "target": "app/levels/page.tsx",
          "expectation": "Page renders three puzzles with lock/unlock state sourced from puzzle data and progression service."
        },
        {
          "name": "WorkspaceWarningComponent",
          "kind": "contains_text",
          "target": "components/Workspace/DisconnectedWarning.tsx",
          "expectation": "Displays 'Oops!' copy plus hint reason when blocks are disconnected or failures occur."
        },
        {
          "name": "ExecutionControls",
          "kind": "contains_text",
          "target": "components/Controls/ExecutionControls.tsx",
          "expectation": "Renders Play, Reset, speed toggle, and keyboard handlers with aria labels and high-contrast styling."
        },
        {
          "name": "WebGLRendererFile",
          "kind": "file_exists",
          "target": "lib/game/renderer/webglPipeline.ts",
          "expectation": "Implements WebGL2 scene rendering for puzzles, failure cues, speed modes, and analytics replay playback."
        },
        {
          "name": "AnalyticsDashboardComponent",
          "kind": "contains_text",
          "target": "components/Analytics/AnalyticsDashboard.tsx",
          "expectation": "Displays totals, puzzle cards, attempt list, event stream, and movement replay tied to API data."
        },
        {
          "name": "GoalNarrationTTS",
          "kind": "contains_text",
          "target": "components/Puzzles/GoalNarration.tsx",
          "expectation": "Goal narration section offers optional text-to-speech playback for accessibility."
        }
      ]
    }
  ]
}