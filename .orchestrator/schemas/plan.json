{
  "type": "object",
  "additionalProperties": false,
  "required": [
    "task_summary",
    "project_brief_path",
    "stages",
    "roles",
    "shared_artifacts",
    "contracts",
    "validation_rules",
    "build_expectations",
    "runtime_expectations",
    "worker_tasks"
  ],
  "properties": {
    "task_summary": {
      "type": "string",
      "minLength": 10
    },
    "project_brief_path": {
      "type": "string",
      "const": "Project_description.md"
    },
    "stages": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 3
      },
      "minItems": 10,
      "maxItems": 10
    },
    "roles": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 3
      },
      "minItems": 6,
      "maxItems": 6
    },
    "shared_artifacts": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 3
      },
      "minItems": 4
    },
    "contracts": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 3
      },
      "minItems": 3
    },
    "validation_rules": {
      "type": "array",
      "minItems": 5,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "name",
          "kind",
          "target",
          "expectation"
        ],
        "properties": {
          "name": {
            "type": "string",
            "minLength": 3
          },
          "kind": {
            "enum": [
              "file_exists",
              "contains_text",
              "json_parse",
              "route_contract",
              "sqlite_artifact",
              "offline_command"
            ]
          },
          "target": {
            "type": "string",
            "minLength": 3
          },
          "expectation": {
            "type": "string",
            "minLength": 3
          }
        }
      }
    },
    "build_expectations": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "name",
          "command",
          "offline_safe"
        ],
        "properties": {
          "name": {
            "type": "string",
            "minLength": 3
          },
          "command": {
            "type": "string",
            "minLength": 3
          },
          "offline_safe": {
            "type": "boolean",
            "const": true
          }
        }
      }
    },
    "runtime_expectations": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "name",
          "command",
          "offline_safe"
        ],
        "properties": {
          "name": {
            "type": "string",
            "minLength": 3
          },
          "command": {
            "type": "string",
            "minLength": 3
          },
          "offline_safe": {
            "type": "boolean",
            "const": true
          }
        }
      }
    },
    "worker_tasks": {
      "type": "array",
      "minItems": 2,
      "maxItems": 2,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "role",
          "summary",
          "owned_paths",
          "required_outputs",
          "read_only_inputs",
          "forbidden_paths",
          "dependencies",
          "contracts",
          "validation_rules"
        ],
        "properties": {
          "role": {
            "enum": [
              "Backend Producer",
              "Frontend Producer"
            ]
          },
          "summary": {
            "type": "string",
            "minLength": 10
          },
          "owned_paths": {
            "type": "array",
            "items": {
              "type": "string",
              "minLength": 3
            },
            "minItems": 1
          },
          "required_outputs": {
            "type": "array",
            "items": {
              "type": "string",
              "minLength": 3
            },
            "minItems": 1
          },
          "read_only_inputs": {
            "type": "array",
            "items": {
              "type": "string",
              "minLength": 3
            },
            "minItems": 1
          },
          "forbidden_paths": {
            "type": "array",
            "items": {
              "type": "string",
              "minLength": 3
            },
            "minItems": 1
          },
          "dependencies": {
            "type": "array",
            "items": {
              "type": "string",
              "minLength": 3
            }
          },
          "contracts": {
            "type": "array",
            "items": {
              "type": "string",
              "minLength": 3
            },
            "minItems": 1
          },
          "validation_rules": {
            "type": "array",
            "minItems": 1,
            "items": {
              "type": "object",
              "additionalProperties": false,
              "required": [
                "name",
                "kind",
                "target",
                "expectation"
              ],
              "properties": {
                "name": {
                  "type": "string",
                  "minLength": 3
                },
                "kind": {
                  "enum": [
                    "file_exists",
                    "contains_text",
                    "json_parse",
                    "route_contract",
                    "sqlite_artifact",
                    "offline_command"
                  ]
                },
                "target": {
                  "type": "string",
                  "minLength": 3
                },
                "expectation": {
                  "type": "string",
                  "minLength": 3
                }
              }
            }
          }
        }
      }
    }
  }
}